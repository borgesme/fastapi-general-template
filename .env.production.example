# ============ 生产环境变量参考模板 =============
# docker-compose 使用 docker-compose.yml 中定义的 environment 直注
# 如使用其他方式部署（如 K8s），请复制此文件并改名为 .env，然后填入真实密钥
#
# 启动前请替换为真实密钥：
#   python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-before-deploy
POSTGRES_PASSWORD=change-me-before-deploy

# App
APP_NAME=FastAPI Project
DEBUG=false

# Database（compose 内部网络，由 postgres 服务名解析）
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/fastapi_project

# Redis（compose 内部网络）
REDIS_URL=redis://redis:6379/0

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 日志（生产写文件，output_log=false 控制台无彩色）
LOG_LEVEL=INFO
LOG_DIR=/app/logs
LOG_RETENTION_DAYS=14
OUTPUT_LOG=true